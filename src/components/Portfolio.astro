---
import { stegaClean } from '@sanity/client/stega';

interface Project {
  title?: string;
  href?: string;
  image?: string;
  imageSrc?: string;
  tags?: string;
  summary?: string;
}

interface PortfolioSection {
  title?: string;
  viewAllLabel?: string;
  viewAllHref?: string;
  projects?: Project[];
}

interface Props {
  section?: PortfolioSection | null;
}

const defaultProjects: Project[] = [
  {
    title: 'Avant Rent a Car',
    href: '/portafolio/avant-rent-a-car',
    image: '/images/3-20-1-p-800.png',
    tags: 'Redes, Meta Ads, Sitio Web, CRM',
    summary:
      'Avant llegó con tres necesidades: mejorar posicionamiento orgánico, optimizar el ROI de Google Ads y resolver fallas técnicas del sitio que afectaban rendimiento, seguridad, UX y conversión.',
  },
  {
    title: 'Diazar',
    href: '/portafolio/diazar',
    image: '/images/5-20-1-p-800.png',
    tags: 'Redes, Meta Ads, Sitio Web, CRM',
    summary:
      'Diazar buscaba posicionarse a nivel nacional, renovar su sitio y fortalecer su marca digital para captar leads calificados desde web y redes.',
  },
  {
    title: 'Happy Store',
    href: '/portafolio/happy-store',
    image: '/images/9-201-p-800.png',
    tags: 'Redes, Meta Ads, Sitio Web, CRM',
    summary:
      'Happy Store quería más visibilidad de marca, alcance en redes y ventas online con contenido visual y pauta enfocada en conversión.',
  },
  {
    title: 'Península Project',
    href: '/portafolio/peninsula-project',
    image: '/images/10-201-p-800.png',
    tags: 'Redes, Meta Ads, Sitio Web, CRM',
    summary:
      'Península Project buscaba reconocimiento en un mercado turístico competitivo y atraer viajeros con experiencias auténticas vía redes y pauta.',
  },
];

const { section } = Astro.props;
const title = section?.title ?? 'Resultados comprobados, proyectos que resaltan.';
const viewAllLabel = section?.viewAllLabel ?? 'Ver todos los proyectos';
const viewAllHref = stegaClean(section?.viewAllHref ?? '/portafolio');
const projects = (section?.projects?.length ? section.projects : defaultProjects).map((p) => ({
  ...p,
  href: stegaClean(p.href ?? '#'),
  image: stegaClean(p.imageSrc ?? p.image ?? ''),
}));
---

<section class="portfolio section-pad bg-alt" data-reveal>
  <div class="padding-global">
    <div class="container-large">
      <div class="portfolio__header" data-reveal-item>
        <h2>{title}</h2>
        <a href={viewAllHref} class="portfolio__all">{viewAllLabel}</a>
      </div>

      <div class="portfolio__grid">
        {
          projects.map((project) => (
            <a href={project.href} class="project-card" data-reveal-item>
              <img src={project.image} alt={project.title} loading="lazy" width="640" height="400" />
              <div class="project-card__body">
                <p class="project-card__tags">{project.tags}</p>
                <h3>{project.title}</h3>
                <p>{project.summary}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .section-pad {
    padding: 4rem 0;
  }

  .bg-alt {
    background: var(--color-section-alt);
    color: var(--color-text);
  }

  .portfolio__header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .portfolio__header h2 {
    margin: 0;
    max-width: 28rem;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
  }

  .portfolio__all {
    font-weight: var(--fw-medium);
    text-decoration: underline;
  }

  .portfolio__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    border-radius: 24px;
    overflow: hidden;
    background: #fff;
    box-shadow: var(--shadow-border);
    border: 0;
    color: inherit;
    transition-property: transform, box-shadow, scale;
    transition-duration: 150ms;
    transition-timing-function: ease-out;
  }

  .project-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-border-hover);
  }

  .project-card:active {
    scale: 0.96;
  }

  .project-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .project-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-card__tags {
    margin: 0;
    font-size: 0.75rem;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .project-card h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .project-card p:last-child {
    margin: 0;
    color: #555;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  @media (max-width: 767px) {
    .portfolio__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
