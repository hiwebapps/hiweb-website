---
import Layout from '../layouts/Layout.astro';
import SectionRenderer from '../components/SectionRenderer.astro';
import { faqsQuery, homePageQuery, testimonialsQuery } from '../sanity/queries';
import { loadQuery } from '../sanity/lib/load-query';
import { getDraftModeProps } from '../sanity/lib/draft-mode';
import { urlFor } from '../sanity/image';

export const prerender = false;

const draft = getDraftModeProps(Astro.cookies);

const [{ data: homePage }, { data: testimonials }, { data: faqs }] = await Promise.all([
  loadQuery({ query: homePageQuery, ...draft }),
  loadQuery({ query: testimonialsQuery, ...draft }),
  loadQuery({ query: faqsQuery, ...draft }),
]);

const title =
  homePage?.metaTitle ??
  homePage?.title ??
  'Digital Marketing Agency in Mexico | Hiweb';
const description =
  homePage?.metaDescription ??
  'Agencia de marketing digital en México. SEO, Ads, redes sociales y desarrollo web con resultados medibles. Agenda tu auditoría.';
const ogImage = homePage?.ogImage
  ? urlFor(homePage.ogImage).width(1200).height(630).url()
  : '/images/hiweb-20team.avif';
---

<Layout title={title} description={description} ogImage={ogImage}>
  <SectionRenderer
    sections={homePage?.sections}
    testimonials={testimonials ?? []}
    faqs={faqs ?? []}
  />
</Layout>

<script>
  import { initHomeAnimations } from '../lib/animations/home';

  let ctx: ReturnType<typeof initHomeAnimations> | undefined;

  function boot() {
    ctx?.revert();
    ctx = initHomeAnimations();
  }

  document.addEventListener('astro:page-load', boot);
  document.addEventListener('astro:after-swap', () => ctx?.revert());
  boot();
</script>
