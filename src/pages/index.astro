---
import { sanityClient } from 'sanity:client';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Portfolio from '../components/Portfolio.astro';
import Experience from '../components/Experience.astro';
import Process from '../components/Process.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import { faqsQuery, testimonialsQuery } from '../sanity/queries';

const [testimonials, faqs] = await Promise.all([
  sanityClient.fetch(testimonialsQuery),
  sanityClient.fetch(faqsQuery),
]);
---

<Layout
  title="Digital Marketing Agency in Mexico | Hiweb"
  description="Agencia de marketing digital en México. SEO, Ads, redes sociales y desarrollo web con resultados medibles. Agenda tu auditoría."
  ogImage="/images/hiweb-20team.avif"
>
  <Hero />
  <About />
  <Services />
  <Portfolio />
  <Experience testimonials={testimonials ?? []} />
  <Process />
  <Faq faqs={faqs ?? []} />
  <FinalCta />
</Layout>

<script>
  import { initHomeAnimations } from '../lib/animations/home';

  let ctx: ReturnType<typeof initHomeAnimations> | undefined;

  function boot() {
    ctx?.revert();
    ctx = initHomeAnimations();
  }

  document.addEventListener('astro:page-load', boot);
  document.addEventListener('astro:after-swap', () => ctx?.revert());
  boot();
</script>
