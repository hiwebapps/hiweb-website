---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Hiweb Marketing | Migración en progreso">
  <main class="scaffold">
    <p class="eyebrow">Fase 1 · Scaffold listo</p>
    <h1>Hiweb Marketing</h1>
    <p>
      Stack: Astro + Sanity + GSAP + Vercel. Studio embebido en
      <a href="/admin">/admin</a>.
    </p>
  </main>
</Layout>

<style>
  .scaffold {
    min-height: 100vh;
    display: grid;
    place-content: center;
    gap: 0.75rem;
    padding: 2rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0;
    font-size: 0.875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  h1 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
  }

  p {
    margin: 0;
    max-width: 36rem;
  }

  a {
    text-decoration: underline;
  }
</style>
