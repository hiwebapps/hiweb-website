---
import { sanityClient } from 'sanity:client';
import Layout from '../../layouts/Layout.astro';
import { postsQuery } from '../../sanity/queries';
import { urlFor } from '../../sanity/image';

const posts = await sanityClient.fetch(postsQuery);
---

<Layout
  title="Blog | Hiweb Marketing"
  description="Artículos de marketing digital, SEO, Ads y desarrollo web."
>
  <section class="blog-index">
    <div class="padding-global">
      <div class="container-large">
        <header class="blog-index__header">
          <p class="eyebrow">Blog</p>
          <h1>Artículos de marketing digital</h1>
          <p class="lede">Contenido editorial desde Sanity — workflow de prueba Fase 3.</p>
        </header>

        {
          posts?.length ? (
            <ul class="blog-index__grid">
              {posts.map((post) => (
                <li>
                  <a href={`/blogs/${post.slug}`} class="blog-card">
                    {post.mainImage ? (
                      <img
                        src={urlFor(post.mainImage).width(640).height(400).url()}
                        alt={post.mainImage.alt ?? post.title}
                        class="blog-card__image"
                        width="640"
                        height="400"
                        loading="lazy"
                      />
                    ) : (
                      <div class="blog-card__placeholder" />
                    )}
                    <div class="blog-card__body">
                      {post.categories?.length ? (
                        <p class="blog-card__cats">
                          {post.categories.map((c) => c?.title).filter(Boolean).join(' · ')}
                        </p>
                      ) : null}
                      <h2>{post.title}</h2>
                      {post.excerpt ? <p>{post.excerpt}</p> : null}
                      {post.publishedAt ? (
                        <time datetime={post.publishedAt}>
                          {new Date(post.publishedAt).toLocaleDateString('es-MX', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric',
                          })}
                        </time>
                      ) : null}
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="empty">Aún no hay artículos publicados. Créalos en /admin.</p>
          )
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .blog-index {
    padding: 4rem 0 6rem;
    color: var(--color-white);
  }

  .blog-index__header {
    max-width: 40rem;
    margin-bottom: 3rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: var(--text-sm);
    color: var(--color-gris);
  }

  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .lede {
    margin: 0;
    color: var(--color-off-white);
  }

  .blog-index__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: 24px;
    overflow: hidden;
    background: #16161a;
    box-shadow: var(--shadow-border-dark);
    border: 0;
    color: inherit;
    transition-property: box-shadow, transform, scale;
    transition-duration: 150ms;
    transition-timing-function: ease-out;
  }

  .blog-card:hover {
    box-shadow: var(--shadow-border-dark-hover);
    transform: translateY(-2px);
  }

  .blog-card:active {
    scale: 0.96;
  }

  .blog-card__image,
  .blog-card__placeholder {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background: #222;
  }

  .blog-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
  }

  .blog-card__cats {
    margin: 0;
    font-size: 0.75rem;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .blog-card__body h2 {
    margin: 0;
    font-size: 1.25rem;
  }

  .blog-card__body p {
    margin: 0;
    color: var(--color-off-white);
    font-size: 0.95rem;
  }

  time {
    margin-top: auto;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .empty {
    color: var(--color-off-white);
  }
</style>
