# Sanity (public — used by Astro + embedded Studio)
PUBLIC_SANITY_PROJECT_ID=fxardjr1
PUBLIC_SANITY_DATASET=production
SANITY_STUDIO_PROJECT_ID=fxardjr1
SANITY_STUDIO_DATASET=production

# Required for Visual Editing / Presentation (Viewer token — server-only)
# Create at https://www.sanity.io/manage → Project → API → Tokens
SANITY_API_READ_TOKEN=

# Preview origin for Presentation (optional when Studio is embedded at /admin).
# On Vercel leave unset so the embedded Studio uses location.origin.
# Local standalone studio: http://localhost:4321
# SANITY_STUDIO_PREVIEW_URL=http://localhost:4321

# Fase 5 — Sanity → Vercel rebuild
# Shared secret: Sanity webhook sends `Authorization: Bearer <secret>`
# to POST /api/sanity-webhook (set the same value in Vercel env).
SANITY_REVALIDATE_SECRET=

# Used only by /api/sanity-webhook to call Vercel Redeploy API
# (create at https://vercel.com/account/tokens — do not commit)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
